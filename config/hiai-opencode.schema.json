{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "hiai-opencode Configuration",
  "description": "User-facing hiai-opencode config. Users choose 10+ primary agent models, service auth placeholders, and enable/disable MCP/LSP integrations. Internal routing derives hidden agents and task categories from these model slots.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "description": "Config format version. Semantic versioning; bump on breaking schema changes."
    },
    "models": {
      "type": "object",
      "description": "The only user-facing model source of truth. Use fully qualified OpenCode model IDs.",
      "additionalProperties": false,
      "properties": {
        "bob": {
          "$ref": "#/definitions/modelSlot"
        },
        "coder": {
          "$ref": "#/definitions/modelSlot"
        },
        "strategist": {
          "$ref": "#/definitions/modelSlot"
        },
        "manager": {
          "$ref": "#/definitions/modelSlot"
        },
        "critic": {
          "$ref": "#/definitions/modelSlot"
        },
        "designer": {
          "$ref": "#/definitions/modelSlot"
        },
        "researcher": {
          "$ref": "#/definitions/modelSlot"
        },
        "writer": {
          "$ref": "#/definitions/modelSlot"
        },
        "vision": {
          "$ref": "#/definitions/modelSlot"
        },
        "sub": {
          "$ref": "#/definitions/modelSlot"
        }
      },
      "required": [
        "bob",
        "coder",
        "strategist",
        "manager",
        "critic",
        "designer",
        "researcher",
        "writer",
        "vision",
        "sub"
      ]
    },
    "auth": {
      "type": "object",
      "description": "Service auth placeholders. Keys: stitch, context7, firecrawl.",
      "additionalProperties": false,
      "properties": {
        "stitch": {
          "type": "string",
          "description": "Stitch AI API key placeholder, e.g. {env:HIAI_STITCH_AUTH}"
        },
        "context7": {
          "type": "string",
          "description": "Context7 API key placeholder, e.g. {env:HIAI_CONTEXT7_AUTH}"
        },
        "firecrawl": {
          "type": "string",
          "description": "Firecrawl API key placeholder, e.g. {env:FIRECRAWL_API_KEY}"
        }
      }
    },
    "mcp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stitch": {
          "$ref": "#/definitions/toggle"
        },
        "sequential-thinking": {
          "$ref": "#/definitions/toggle"
        },
        "mempalace": {
          "$ref": "#/definitions/mempalaceToggle"
        },
        "context7": {
          "$ref": "#/definitions/toggle"
        },
        "grep_app": {
          "$ref": "#/definitions/toggle"
        }
      }
    },
    "lsp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "typescript": {
          "$ref": "#/definitions/toggle"
        },
        "svelte": {
          "$ref": "#/definitions/toggle"
        },
        "eslint": {
          "$ref": "#/definitions/toggle"
        },
        "bash": {
          "$ref": "#/definitions/toggle"
        },
        "pyright": {
          "$ref": "#/definitions/toggle"
        }
      }
    },
    "skill_discovery": {
      "type": "object",
      "description": "Controls external skill folder scanning. Defaults keep installs deterministic.",
      "additionalProperties": false,
      "properties": {
        "config_sources": {
          "type": "boolean",
          "default": true
        },
        "project_opencode": {
          "type": "boolean",
          "default": true
        },
        "global_opencode": {
          "type": "boolean",
          "default": false
        },
        "project_claude": {
          "type": "boolean",
          "default": false
        },
        "global_claude": {
          "type": "boolean",
          "default": false
        },
        "project_agents": {
          "type": "boolean",
          "default": false
        },
        "global_agents": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "subtask2": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "replace_generic": {
          "type": "boolean"
        }
      }
    },
    "ralph_loop": {
      "type": "object",
      "description": "Ralph-loop continuation engine config. Auto-start threshold 0 disables auto-start.",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Whether ralph-loop is enabled."
        },
        "auto_start_threshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "default": 0,
          "description": "Auto-start ralph-loop when this many or more open todos exist in a single session. 0 disables auto-start."
        }
      }
    }
  },
  "required": [
    "models"
  ],
  "definitions": {
    "modelSlot": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "properties": {
            "model": {
              "type": "string"
            },
            "recommended": {
              "enum": [
                "xhigh",
                "high",
                "middle",
                "fast",
                "vision",
                "writing",
                "design"
              ]
            }
          },
          "required": [
            "model"
          ],
          "additionalProperties": false
        }
      ]
    },
    "toggle": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        }
      },
      "required": [
        "enabled"
      ],
      "additionalProperties": false
    },
    "mempalaceToggle": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "pythonPath": {
          "type": "string",
          "description": "Optional explicit Python executable for MemPalace (for example: ./.venv/bin/python)."
        }
      },
      "required": [
        "enabled"
      ],
      "additionalProperties": false
    }
  }
}