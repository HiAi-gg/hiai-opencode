{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "hiai-opencode Configuration",
  "description": "User-facing hiai-opencode config. Users choose 10+ primary agent models, service auth placeholders, and enable/disable MCP/LSP integrations. Internal routing derives hidden agents and task categories from these model slots.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "default": "0.3.5",
      "description": "Config format version. Semantic versioning; bump on breaking schema changes."
    },
    "models": {
      "type": "object",
      "description": "The only user-facing model source of truth. Use fully qualified OpenCode model IDs. Canonical slots: bob, build, plan, manager, critic, designer, explore, writer, vision, general.",
      "additionalProperties": false,
      "properties": {
        "bob": {
          "$ref": "#/definitions/modelSlot"
        },
        "build": {
          "$ref": "#/definitions/modelSlot"
        },
        "plan": {
          "$ref": "#/definitions/modelSlot"
        },
        "manager": {
          "$ref": "#/definitions/modelSlot"
        },
        "critic": {
          "$ref": "#/definitions/modelSlot"
        },
        "designer": {
          "$ref": "#/definitions/modelSlot"
        },
        "explore": {
          "$ref": "#/definitions/modelSlot"
        },
        "writer": {
          "$ref": "#/definitions/modelSlot"
        },
        "vision": {
          "$ref": "#/definitions/modelSlot"
        },
        "general": {
          "$ref": "#/definitions/modelSlot"
        }
      },
      "required": [
        "bob",
        "build",
        "plan",
        "manager",
        "critic",
        "designer",
        "explore",
        "writer",
        "vision",
        "general"
      ]
    },
    "auth": {
      "type": "object",
      "description": "Service auth placeholders. Keys: firecrawl.",
      "additionalProperties": false,
      "properties": {
        "firecrawl": {
          "type": "string",
          "description": "Firecrawl API key placeholder, e.g. {env:FIRECRAWL_API_KEY}"
        }
      }
    },
    "mcp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sequential-thinking": {
          "$ref": "#/definitions/toggle"
        },
        "grep_app": {
          "$ref": "#/definitions/toggle"
        }
      }
    },
    "lsp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "typescript": {
          "$ref": "#/definitions/toggle"
        },
        "svelte": {
          "$ref": "#/definitions/toggle"
        },
        "eslint": {
          "$ref": "#/definitions/toggle"
        },
        "bash": {
          "$ref": "#/definitions/toggle"
        },
        "pyright": {
          "$ref": "#/definitions/toggle"
        }
      }
    },
    "skill_discovery": {
      "type": "object",
      "description": "Controls external skill folder scanning. Defaults keep installs deterministic.",
      "additionalProperties": false,
      "properties": {
        "config_sources": {
          "type": "boolean",
          "default": true
        },
        "project_opencode": {
          "type": "boolean",
          "default": true
        },
        "global_opencode": {
          "type": "boolean",
          "default": false
        },
        "project_claude": {
          "type": "boolean",
          "default": false
        },
        "global_claude": {
          "type": "boolean",
          "default": false
        },
        "project_agents": {
          "type": "boolean",
          "default": false
        },
        "global_agents": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "loop": {
      "type": "object",
      "description": "Loop continuation engine config. Auto-start threshold 0 disables auto-start.",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Whether loop is enabled."
        },
        "auto_start_threshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "default": 0,
          "description": "Auto-start loop when this many or more open todos exist in a single session. 0 disables auto-start."
        }
      }
    },
    "tool_settings": {
      "type": "object",
      "description": "Per-tool configuration overrides keyed by tool name. Values are numeric tunables (e.g. budgets, thresholds).",
      "additionalProperties": {
        "type": "number"
      }
    }
  },
  "required": [
    "models"
  ],
  "definitions": {
    "modelSlot": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "properties": {
            "model": {
              "type": "string"
            },
            "recommended": {
              "enum": [
                "xhigh",
                "high",
                "middle",
                "fast",
                "vision",
                "writing",
                "design"
              ]
            }
          },
          "required": [
            "model"
          ],
          "additionalProperties": false
        }
      ]
    },
    "toggle": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        }
      },
      "required": [
        "enabled"
      ],
      "additionalProperties": false
    }
  }
}
