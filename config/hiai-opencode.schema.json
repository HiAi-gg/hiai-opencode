{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "hiai-opencode Configuration",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "string" },
    "subagent_depth": { "type": "integer", "minimum": 1, "default": 2, "description": "Use 2 for Bob → Manager → worker." },
    "models": { "type": "object", "additionalProperties": { "$ref": "#/definitions/modelSlot" } },
    "mcp": { "type": "object", "additionalProperties": { "$ref": "#/definitions/toggle" } },
    "lsp": { "type": "object", "additionalProperties": { "$ref": "#/definitions/lsp" } },
    "agent_restrictions": { "type": "object", "additionalProperties": { "type": "object", "additionalProperties": { "type": "boolean" } } },
    "hooks": { "$ref": "#/definitions/disabledList" },
    "tools": { "$ref": "#/definitions/disabledList" },
    "agent_overrides": { "type": "object", "additionalProperties": { "type": "object", "properties": { "model": { "type": "string" }, "prompt_append": { "type": "string" } }, "additionalProperties": false } },
    "disabled_agents": { "type": "array", "items": { "type": "string" } },
    "disabled_hooks": { "type": "array", "items": { "type": "string" } },
    "auth": { "type": "object", "additionalProperties": { "type": "string" } },
    "background_manager": { "type": "object", "properties": { "concurrency_limit": { "type": "integer", "minimum": 1, "description": "Deprecated no-op." }, "stale_timeout_ms": { "type": "integer", "minimum": 1, "description": "Deprecated no-op." }, "circuit_breaker": { "type": "object", "properties": { "enabled": { "type": "boolean" }, "max_tool_calls": { "type": "integer", "minimum": 1 }, "consecutive_threshold": { "type": "integer", "minimum": 1 } }, "additionalProperties": false } }, "additionalProperties": false },
    "telemetry": { "type": "object", "properties": { "enabled": { "type": "boolean" }, "endpoint": { "type": "string" }, "serviceName": { "type": "string" }, "sampleRate": { "type": "number", "minimum": 0, "maximum": 1 } }, "required": ["enabled"], "additionalProperties": false },
    "completion": { "type": "object", "properties": { "enabled": { "type": "boolean" }, "max_auto_continues": { "type": "integer", "minimum": 0 }, "require_critic": { "type": "boolean" }, "ui_globs": { "type": "array", "items": { "type": "string" } }, "reset_on_user_message": { "type": "boolean" } }, "additionalProperties": false },
    "caveman": { "type": "object", "additionalProperties": true },
    "dream": { "$ref": "#/definitions/periodic" },
    "distill": { "$ref": "#/definitions/periodic" },
    "worktreeConfig": { "type": "object", "properties": { "enabled": { "type": "boolean" }, "base_dir": { "type": "string" } }, "additionalProperties": false },
    "workspace": { "type": "object", "properties": { "enabled": { "type": "boolean" }, "cache_results": { "type": "boolean" } }, "additionalProperties": false },
    "loop": { "type": "object", "additionalProperties": true },
    "tool_settings": { "type": "object", "additionalProperties": { "type": "number" } },
    "shell_env": { "type": "object", "properties": { "variables": { "type": "array", "items": { "type": "string" } }, "inject_in": { "type": "array", "items": { "type": "string" } }, "env_file": { "type": "string" } }, "additionalProperties": false }
  },
  "definitions": {
    "modelSlot": { "type": "object", "properties": { "model": { "type": "string" }, "recommended": { "type": "string" } }, "required": ["model"], "additionalProperties": false },
    "toggle": { "type": "object", "properties": { "enabled": { "type": "boolean" } }, "required": ["enabled"], "additionalProperties": false },
    "lsp": { "type": "object", "properties": { "enabled": { "type": "boolean" }, "command": { "type": "string" }, "args": { "type": "array", "items": { "type": "string" } }, "initializationOptions": { "type": "object" }, "env": { "type": "object", "additionalProperties": { "type": "string" } } }, "additionalProperties": false },
    "disabledList": { "type": "object", "properties": { "disabled": { "type": "array", "items": { "type": "string" } } }, "additionalProperties": false },
    "periodic": { "type": "object", "properties": { "auto": { "type": "boolean" }, "interval_days": { "type": "number", "minimum": 1 }, "model": { "type": "string" } }, "additionalProperties": false }
  }
}
