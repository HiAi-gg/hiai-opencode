# hiai-opencode environment variables
# Copy this file to .env and fill in your values.
#
# REQUIRED keys (for full functionality):
#   - FIRECRAWL_API_KEY    : Web scraping/search (CLI skill, NOT MCP)
#   - STITCH_AI_API_KEY    : Stitch AI design MCP
#   - MEMPALACE_PYTHON     : Python interpreter for MemPalace MCP
#   - HIAI_MCP_AUTO_INSTALL: Set to 1 to allow auto-install of Python packages
#
# OPTIONAL keys:
#   - CONTEXT7_API_KEY     : Code documentation search MCP
#   - OLLAMA_BASE_URL      : Local Ollama endpoint
#   - OLLAMA_MODEL         : Ollama model ID
#   - MEMPALACE_PALACE_PATH: MemPalace data directory
#   - HIAI_OPENCODE_*      : Plugin behavior controls
#
# NOTE: Model provider credentials (OPENROUTER, OPENAI, ANTHROPIC) are
# configured via OpenCode Connect, NOT here.

# ============================================
# REQUIRED: Web Scraping (Firecrawl CLI skill)
# ============================================
# Firecrawl is a CLI skill (not MCP). Key must be in shell env.
# Get your key at: https://firecrawl.dev
# FIRECRAWL_API_KEY=fc-your_key_here

# ============================================
# REQUIRED: Stitch AI (MCP)
# ============================================
# Stitch AI is a remote MCP for UI generation.
# Get your key at: https://stitch.google.com
# STITCH_AI_API_KEY=your_stitch_key_here

# ============================================
# REQUIRED: MemPalace Python Interpreter (MCP)
# ============================================
# Path to Python 3.9+ interpreter with mempalace package installed.
# The launcher prefers `uv`; otherwise uses this path.
# MEMPALACE_PYTHON=python3

# ============================================
# REQUIRED: Auto-Install Python Packages
# ============================================
# Set to 1 to allow automatic `pip install mempalace` on first start.
# Set to 0/false/no to disable (you must install manually).
# HIAI_MCP_AUTO_INSTALL=1

# ============================================
# OPTIONAL: Context7 Code Documentation (MCP)
# ============================================
# Context7 is optional. Works without a key, but key unlocks higher limits.
# CONTEXT7_API_KEY=your_context7_key_here

# ============================================
# OPTIONAL: Local Models (Ollama)
# ============================================
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3.5:4b

# ============================================
# OPTIONAL: MemPalace Data Directory
# ============================================
# MEMPALACE_PALACE_PATH=./.opencode/palace

# ============================================
# OPTIONAL: Plugin Behavior Controls
# ============================================
# Log level: debug, info, warn, error
# HIAI_OPENCODE_LOG_LEVEL=info

# Auto-export .mcp.json: if-missing (default), always, force, 0/false/no/off
# HIAI_OPENCODE_AUTO_EXPORT_MCP=if-missing

# Override static MCP export path
# HIAI_OPENCODE_MCP_EXPORT_PATH=./.opencode/.mcp.json

# CLI export safety mode: safe (default), force
# HIAI_OPENCODE_EXPORT_MCP_MODE=safe
