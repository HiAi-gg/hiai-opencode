# hiai-opencode environment variables
# Copy this file to .env and fill in your values.
#
# REQUIRED keys (for full functionality):
#   - FIRECRAWL_API_KEY    : Web scraping/search (CLI skill, NOT MCP)
#
# OPTIONAL keys:
#   - CONTEXT7_API_KEY     : On-demand code documentation search (CLI skill)
#   - OLLAMA_BASE_URL      : Local Ollama endpoint
#   - OLLAMA_MODEL         : Ollama model ID
#   - HIAI_OPENCODE_*      : Plugin behavior controls
#
# NOTE: Model provider credentials (OPENROUTER, OPENAI, ANTHROPIC) are
# configured via OpenCode Connect, NOT here.
#
# NOTE: Stitch AI, Context7, and MemPalace MCP servers were removed from the
# default MCP registry in v0.3.0. Context7 remains available as an on-demand
# CLI skill via `skill("explore/context7")`. Stitch and MemPalace must be
# configured manually if needed.

# ============================================
# REQUIRED: Web Scraping (Firecrawl CLI skill)
# ============================================
# Firecrawl is a CLI skill (not MCP). Key must be in shell env.
# Get your key at: https://firecrawl.dev
# FIRECRAWL_API_KEY=fc-your_key_here

# ============================================
# OPTIONAL: Context7 Code Documentation (CLI skill)
# ============================================
# Context7 is available as an on-demand CLI skill via skill("explore/context7").
# Works without a key, but key unlocks higher limits.
# CONTEXT7_API_KEY=your_context7_key_here

# ============================================
# OPTIONAL: Local Models (Ollama)
# ============================================
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3.5:4b

# ============================================
# OPTIONAL: Plugin Behavior Controls
# ============================================
# Log level: debug, info, warn, error
# HIAI_OPENCODE_LOG_LEVEL=info

# Auto-export .mcp.json: if-missing (default), always, force, 0/false/no/off
# HIAI_OPENCODE_AUTO_EXPORT_MCP=if-missing

# Override static MCP export path
# HIAI_OPENCODE_MCP_EXPORT_PATH=./.opencode/.mcp.json

# CLI export safety mode: safe (default), force
# HIAI_OPENCODE_EXPORT_MCP_MODE=safe
