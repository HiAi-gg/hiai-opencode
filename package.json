{
  "name": "hiai-opencode",
  "version": "1.0.0",
  "description": "Unified OpenCode plugin — agents, MCPs, skills, LSP, permissions in one install",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "skills/",
    "assets/",
    "config/"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --format esm",
    "typecheck": "tsc --noEmit",
    "prompts:measure": "bun run scripts/measure_prompts.ts",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@tarquinen/opencode-dcp": "github:Opencode-DCP/opencode-dynamic-context-pruning",
    "bun-pty": "^0.4.8",
    "@opencode-ai/plugin": "^1.4.0",
    "@opencode-ai/sdk": "^1.4.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@ast-grep/napi": "^0.37.0",
    "zod": "^4.3.0",
    "jsonc-parser": "^3.3.1",
    "js-yaml": "^4.1.0",
    "yaml": "^2.7.0",
    "picocolors": "^1.1.0",
    "commander": "^13.1.0",
    "vscode-jsonrpc": "^8.2.0",
    "vscode-languageserver-protocol": "^3.17.5",
    "vscode-languageserver-types": "^3.17.5",
    "picomatch": "^4.0.3",
    "diff": "^7.0.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/picomatch": "^4.0.3",
    "@types/diff": "^7.0.0",
    "bun-types": "^1.3.12"
  }
}
