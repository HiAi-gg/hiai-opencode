{
  "name": "@hiai-gg/hiai-opencode",
  "version": "0.2.5",
  "description": "Unified OpenCode plugin — 14-agent model (9 visible + 5 hidden) with MCP integrations, browser automation, bundled skills, 150+ design systems, LSP, and safer defaults.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "hiai-opencode": "./assets/cli/hiai-opencode.mjs"
  },
  "exports": {
    ".": {
      "import": "dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "docs/",
    "skills/",
    "assets/",
    "config/hiai-opencode.schema.json",
    "config/opencode.json",
    "design-systems/",
    "prompt-templates/",
    ".opencode/skills/",
    ".env.example",
    "AGENTS.md",
    "ARCHITECTURE.md",
    "LICENSE.md",
    "README.md",
    "hiai-opencode.json"
  ],
  "keywords": [
    "opencode",
    "opencode-plugin",
    "agents",
    "ai-agents",
    "multi-agent",
    "multi-agent-systems",
    "orchestration",
    "mcp",
    "model-context-protocol",
    "stitch",
    "context7",
    "mempalace",
    "firecrawl",
    "agent-browser",
    "browser-automation",
    "playwright-alternative",
    "lsp",
    "skills",
    "design-systems",
    "llm",
    "anthropic",
    "openai",
    "hiai",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HiAi-gg/hiai-opencode.git"
  },
  "homepage": "https://github.com/HiAi-gg/hiai-opencode#readme",
  "bugs": {
    "url": "https://github.com/HiAi-gg/hiai-opencode/issues"
  },
  "author": "HiAi",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean:dist": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "bun run clean:dist && bun build src/index.ts --outdir dist --target bun --format esm --minify && tsc --emitDeclarationOnly",
    "build:bundle": "bun build src/index.ts --outdir dist --target bun --format esm",
    "build:types": "tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "ci": "biome ci .",
    "check:docs": "bun run scripts/check-docs.ts",
    "check:bundle-size": "node -e \"const s=require('fs').statSync('dist/index.js').size;console.log('Bundle: '+(s/1024/1024).toFixed(2)+'MB');if(s>3*1024*1024){console.error('FAIL: bundle >3MB');process.exit(1)}else{console.log('OK: bundle <=3MB')}\"",
    "prompts:measure": "bun run scripts/measure-prompts.ts",
    "check:todos": "node scripts/check-todos.mjs || echo 'No check-todos script'",
    "pack:check": "npm pack --dry-run",
    "prepare": "husky",
    "prepublishOnly": "bun run typecheck && bun run test && bun run build && bun run pack:check"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@opencode-ai/plugin": "^1.16.2",
    "@opencode-ai/sdk": "^1.16.2",
    "bun-pty": "^0.4.8",
    "commander": "^13.1.0",
    "diff": "^7.0.0",
    "jsonc-parser": "^3.3.1",
    "picocolors": "^1.1.0",
    "picomatch": "^4.0.3",
    "vscode-jsonrpc": "^8.2.0",
    "vscode-languageserver-protocol": "^3.17.5",
    "vscode-languageserver-types": "^3.17.5",
    "yaml": "^2.7.0",
    "zod": "^4.3.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/diff": "^7.0.2",
    "@types/picomatch": "^4.0.3",
    "bun-types": "^1.3.12",
    "husky": "^9.1.7",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.3.0"
  }
}
