{
  "name": "@hiai-gg/hiai-opencode",
  "version": "0.3.0",
  "description": "HiAi OpenCode Plugin — multi-agent orchestration for OpenCode with 10 agents, LSP tools, browser automation, Memory, Session management, and Caveman protocol",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "skills/",
    "docs/",
    "assets/",
    "config/",
    ".env.example",
    "AGENTS.md",
    "ARCHITECTURE.md",
    "LICENSE.md",
    "README.md",
    "CHANGELOG.md",
    "hiai-opencode.json",
    "bob.json",
    "bob.env.example",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "SECURITY.md"
  ],
  "keywords": [
    "opencode",
    "opencode-plugin",
    "plugin",
    "ai-agents",
    "agents",
    "multi-agent",
    "multi-agent-systems",
    "orchestration",
    "mcp",
    "context7",
    "firecrawl",
    "agent-browser",
    "browser-automation",
    "lsp",
    "skills",
    "llm",
    "openai",
    "anthropic",
    "typescript",
    "hiai",
    "bun",
    "mempalace",
    "caveman"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HiAi-gg/hiai-opencode.git"
  },
  "homepage": "https://github.com/HiAi-gg/hiai-opencode#readme",
  "bugs": {
    "url": "https://github.com/HiAi-gg/hiai-opencode/issues"
  },
  "author": "HiAi",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean:dist": "rm -rf dist",
    "build:bundle": "bun build --target bun --outdir ./dist --entrypoints ./src/index.ts",
    "build:types": "tsc --emitDeclarationOnly --project tsconfig.json",
    "build": "bun run clean:dist && bun run build:bundle && bun run build:types",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test": "bun test",
    "lint": "biome lint src/",
    "lint:fix": "biome lint --write src/",
    "format": "biome format --write src/",
    "format:check": "biome format src/",
    "check": "biome check src/",
    "check:fix": "biome check --write src/",
    "ci": "biome ci .",
    "check:bundle-size": "node scripts/check-bundle-size.mjs",
    "pack:check": "bun run build && npm pack --dry-run",
    "prepublishOnly": "bun run typecheck && bun run test && bun run build && bun run pack:check"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.17.0",
    "@opentelemetry/api": "^1.9.1",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "bun-types": "^1.3.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.3.0"
  }
}
