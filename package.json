{
  "name": "@hiai-gg/hiai-opencode",
  "version": "0.1.6",
  "description": "Unified OpenCode plugin — canonical 12-agent model with bundled skills, MCP integrations, LSP, and permissions in one install.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "hiai-opencode": "./assets/cli/hiai-opencode.mjs"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "src/",
    "skills/",
    "assets/",
    "config/",
    ".env.example",
    "AGENTS.md",
    "ARCHITECTURE.md",
    "LICENSE.md",
    "README.md",
    "hiai-opencode.json"
  ],
  "keywords": [
    "opencode",
    "opencode-plugin",
    "agents",
    "mcp",
    "llm",
    "ai-agents",
    "hiai"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HiAi-gg/hiai-opencode.git"
  },
  "homepage": "https://github.com/HiAi-gg/hiai-opencode#readme",
  "bugs": {
    "url": "https://github.com/HiAi-gg/hiai-opencode/issues"
  },
  "author": "HiAi",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean:dist": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "bun run clean:dist && bun build src/index.ts --outdir dist --target bun --format esm && tsc --emitDeclarationOnly",
    "build:bundle": "bun build src/index.ts --outdir dist --target bun --format esm",
    "build:types": "tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "pack:check": "npm pack --dry-run",
    "prepare": "bun run build",
    "prepublishOnly": "bun run typecheck && bun run test && bun run build && bun run pack:check"
  },
  "dependencies": {
    "bun-pty": "^0.4.8",
    "@opencode-ai/plugin": "^1.4.0",
    "@opencode-ai/sdk": "^1.4.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^4.3.0",
    "jsonc-parser": "^3.3.1",
    "js-yaml": "^4.1.0",
    "yaml": "^2.7.0",
    "picocolors": "^1.1.0",
    "commander": "^13.1.0",
    "vscode-jsonrpc": "^8.2.0",
    "vscode-languageserver-protocol": "^3.17.5",
    "vscode-languageserver-types": "^3.17.5",
    "picomatch": "^4.0.3",
    "diff": "^7.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/picomatch": "^4.0.3",
    "@types/diff": "^7.0.0",
    "bun-types": "^1.3.12",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18",
    "bun": ">=1.1.0"
  }
}
