# HiAi OpenCode Plugin — API Keys & Environment
# All credentials live HERE. Edit this file, then source it or let the plugin read it.
# Format: export VAR_NAME="value"

# --- Skill API Keys ---
export FIRECRAWL_API_KEY=your-firecrawl-key-here
export CONTEXT7_API_KEY=your-context7-key-here

# --- Agent-Browser ---
# AGENT_BROWSER_HEADED=1   # Uncomment to opt into VISIBLE browser (default is headless)
export AGENT_BROWSER_SESSION=hiai-opencode-session

# --- Optional: MCP server env vars ---
# export GREP_APP_API_KEY="your-grep-app-key-here"
