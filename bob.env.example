# HiAi OpenCode Plugin — API Keys & Environment
# Copy this file to bob.env and fill in your keys.
# bob.env is git-ignored and never committed.
#
# Format: export VAR_NAME="value"
# Lines starting with # are comments.
#
# REQUIRED keys (for full functionality):
#   - FIRECRAWL_API_KEY    : Web scraping/search (CLI skill, NOT MCP)
#
# OPTIONAL keys:
#   - CONTEXT7_API_KEY     : On-demand code documentation search (CLI skill)
#   - OLLAMA_BASE_URL      : Local Ollama endpoint
#   - OLLAMA_MODEL         : Ollama model ID
#   - HIAI_OPENCODE_*      : Plugin behavior controls
#   - HIAI_MCP_AUTO_INSTALL: Auto-install MCP dependencies
#   - AGENT_BROWSER_*      : Browser automation settings
#
# NOTE: Model provider credentials (OPENROUTER, OPENAI, ANTHROPIC) are
# configured via OpenCode Connect, NOT here.
#
# NOTE: API keys in hiai-opencode.json use {env:VAR_NAME} placeholders.
# Never put raw API keys in JSON config files.

# ============================================
# REQUIRED: Web Scraping (Firecrawl CLI skill)
# ============================================
# Firecrawl is a CLI skill (not MCP). Key must be available in shell env.
# Get your key at: https://firecrawl.dev
export FIRECRAWL_API_KEY=your-firecrawl-key-here

# ============================================
# OPTIONAL: Context7 Code Documentation (CLI skill)
# ============================================
# Context7 is available as an on-demand CLI skill via skill("explore/context7").
# Works without a key, but key unlocks higher limits.
export CONTEXT7_API_KEY=your-context7-key-here

# ============================================
# OPTIONAL: Agent-Browser Settings
# ============================================
# Uncomment to opt into VISIBLE browser (default is headless)
# AGENT_BROWSER_HEADED=1
export AGENT_BROWSER_SESSION=hiai-opencode-session

# ============================================
# OPTIONAL: Local Models (Ollama)
# ============================================
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3.5:4b

# ============================================
# OPTIONAL: Plugin Behavior Controls
# ============================================
# Log level: debug, info, warn, error
# HIAI_OPENCODE_LOG_LEVEL=info

# Auto-export .mcp.json: if-missing (default), always, force, 0/false/no/off
# HIAI_OPENCODE_AUTO_EXPORT_MCP=if-missing

# Override static MCP export path
# HIAI_OPENCODE_MCP_EXPORT_PATH=./.opencode/.mcp.json

# CLI export safety mode: safe (default), force
# HIAI_OPENCODE_EXPORT_MCP_MODE=safe

# Auto-install MCP dependencies on first use (0/false/no to disable)
# HIAI_MCP_AUTO_INSTALL=1

# ============================================
# OPTIONAL: MCP Server Environment Variables
# ============================================
# Uncomment if you use grep.app with an API key
# export GREP_APP_API_KEY="your-grep-app-key-here"
